# PostgreSQL connection string from Aiven Cloud
# Format: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL="postgresql://avnadmin:PASSWORD@your-pg-host.aivencloud.com:12345/defaultdb?sslmode=require"

# Iron-session secret (must be 32+ chars)
SESSION_SECRET="quizzy-session-secret-must-be-32-chars!!"

# Piston code execution API
PISTON_URL=http://localhost:2000

# Server config
PORT=3000
NODE_ENV=development
